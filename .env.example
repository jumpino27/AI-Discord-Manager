# Discord Bridge Bot
# Copy this file to `.env` and fill in your real values.
# Never commit your real .env file to git.

# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Comma-separated list of Discord user IDs allowed to run commands.
# If empty, only the server owner can run commands.
# Example: AUTHORIZED_USER_IDS=123456789012345678,987654321098765432
AUTHORIZED_USER_IDS=

# Prefix for commands. Examples: ! ? $ >
COMMAND_PREFIX=!
